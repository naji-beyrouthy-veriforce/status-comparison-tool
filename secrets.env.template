# secrets.env.template — committed to git as a setup guide
# To set up: copy this file to secrets.env and fill in your values.
#
#   Windows:  copy secrets.env.template secrets.env
#   Mac/Linux: cp secrets.env.template secrets.env
#
# secrets.env is gitignored and will never be committed.

# -----------------------------------------------------------------------
# Redash API key (required for all automated runs)
# Obtain from your Redash administrator
# -----------------------------------------------------------------------
REDASH_API_KEY=YOUR_REDASH_API_KEY_HERE

# -----------------------------------------------------------------------
# Dynamics 365 API credentials (optional — enables automatic D365 download)
# Obtain from IT: requires an Azure App Registration with a D365 Security Role
# Leave blank to skip D365 auto-download and upload files manually via Tab 1
# -----------------------------------------------------------------------
D365_TENANT_ID=YOUR_AZURE_TENANT_ID_HERE
D365_CLIENT_ID=YOUR_APP_REGISTRATION_CLIENT_ID_HERE
D365_CLIENT_SECRET=YOUR_APP_REGISTRATION_CLIENT_SECRET_HERE
